{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prompt Picker",
  "identifier": "local.promptpicker.dev",
  "version": "1.0.8",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Prompt Picker",
        "width": 760,
        "height": 560,
        "minWidth": 640,
        "minHeight": 460,
        "resizable": true,
        "acceptFirstMouse": true,
        "visible": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "Developer ID Application: Jinhang Yang (2GWPG8KGW5)",
      "hardenedRuntime": true
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/app-icon.png"
    ]
  }
}
