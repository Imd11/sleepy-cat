{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capabilities for Prompt Picker windows",
  "windows": ["main", "prompt-button", "prompt-button-input", "prompt-popover"],
  "permissions": [
    "core:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-app-read-recursive",
    "fs:allow-app-write-recursive",
    "shell:allow-open"
  ]
}
